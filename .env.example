# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Nodeクラスに使うモデル（高精度が必要なため 4o 推奨）
OPENAI_CLASSIFIER_MODEL=gpt-4o
# クエリ型分類・回答生成（コスト重視なら 4o-mini でも可）
OPENAI_GENERATOR_MODEL=gpt-4o-mini
OPENAI_REASONING_EFFORT=low
# ── Embeddings ────────────────────────────────────────────────────────────────
# E5-Mistral-7B-Instruct（入口選定用）
EMBEDDING_MODEL=intfloat/e5-mistral-7b-instruct
# GPU使用: cuda / cpu / mps
EMBEDDING_DEVICE=cpu

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ap_rag_dev

# ── Indexing ──────────────────────────────────────────────────────────────────
# インデックス処理の並列 API 呼び出し数。高いほど高速だが、OpenAI の Tier と
# レートリミットに応じて調整。Tier1 なら 4, Tier2+ なら 8-16 も可。
INDEXING_MAX_WORKERS=4
# グラフキャッシュの親ディレクトリ。文書単位で .json を保存し、再実行時に
# 同じ (classifier_model, reasoning_effort, chunk 設定, prompt_version) なら
# LLM 呼び出しをスキップして復元する。空にするとキャッシュ無効。
GRAPH_CACHE_DIR=.cache/graphs

# ── General ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LLM呼び出しの最大リトライ回数
LLM_MAX_RETRIES=3
